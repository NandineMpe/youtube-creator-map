# Source snapshots are large, immutable, and reproducible from their
# published source. The contract pins each by digest, so the repository
# records what was ingested without carrying the bytes.
data/snapshots/
.DS_Store

# Build output. Anchored to the repo root so it does not also match
# `fixtures/dist`, which is a checked-in, deterministic release the
# cross-stack contract test reads and CI regenerates to detect drift —
# ignoring it would leave CI comparing against nothing.
/dist/
/dist-test/
/apps/web/out/

# Generated by editable installs; reproducible from pyproject.toml.
*.egg-info/
.mypy_cache/
__pycache__/
